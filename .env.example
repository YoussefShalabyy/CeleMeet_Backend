APP_NAME=CeleMeet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# Database — MySQL
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=celebmeet
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# -----------------------------------------------
# Cache — Redis
# -----------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=celebmeet_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------
# Mail
# -----------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@celebmeet.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# JWT
# -----------------------------------------------
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# -----------------------------------------------
# Cloudinary — Media Storage
# -----------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=celebmeet
CLOUDINARY_SIGNED_UPLOADS=true
CLOUDINARY_PRESET_AVATAR=celebmeet_avatar
CLOUDINARY_PRESET_COVER=celebmeet_cover
CLOUDINARY_PRESET_POST=celebmeet_post
CLOUDINARY_PRESET_STORY=celebmeet_story
CLOUDINARY_PRESET_MESSAGE=celebmeet_message
CLOUDINARY_MAX_IMAGE_SIZE=10485760
CLOUDINARY_MAX_VIDEO_SIZE=104857600
CLOUDINARY_MAX_AUDIO_SIZE=20971520

# -----------------------------------------------
# Stream — Chat & Video
# -----------------------------------------------
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_APP_ID=
STREAM_CHAT_TOKEN_TTL=3600
STREAM_VIDEO_TOKEN_TTL=3600
STREAM_REGION=us-east
STREAM_TIMEOUT=10

# -----------------------------------------------
# Paymob — Payment Gateway
# -----------------------------------------------
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_CARD=0
PAYMOB_INTEGRATION_WALLET=0
PAYMOB_INTEGRATION_KIOSK=0
PAYMOB_IFRAME_CARD=0
PAYMOB_IFRAME_WALLET=0
PAYMOB_BASE_URL=https://accept.paymob.com/api
PAYMOB_CURRENCY=EGP
PAYMOB_CALLBACK_URL=/api/v1/payments/callback
PAYMOB_TIMEOUT=30

# -----------------------------------------------
# Wallet Business Rules
# -----------------------------------------------
WALLET_COMMISSION_RATE=0.20
WALLET_MIN_WITHDRAWAL_COINS=1000
WALLET_COINS_PER_UNIT=100
WALLET_MESSAGE_REFUND_HOURS=48
WALLET_MIN_CALL_HOLD_MINUTES=1

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=

CLOUDINARY_URL=
